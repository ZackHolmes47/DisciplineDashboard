@model DisciplineDashboard.Models.Challenge

@{
    ViewData["Title"] = "Create Challenge";
}

<div class="page-section">

    @* Page header *@
    <div class="page-header">
        <div>
            <p class="page-kicker">New Challenge</p>
            <h1>Create a Challenge</h1>
            <p>Set a measurable commitment you want to complete.</p>
        </div>
    </div>

    @* Challenge form *@
    <div class="form-card">

        <form asp-action="Create" method="post">

            @* Challenge name *@
            <div class="mb-4">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            @* Challenge category *@
            <div class="mb-4">
                <label asp-for="Category" class="form-label"></label>

                <select asp-for="Category" class="form-select">
                    <option value="">Select a category...</option>
                    <option>Faith</option>
                    <option>Health</option>
                    <option>Personal</option>
                    <option>Work</option>
                    <option>Relationships</option>
                    <option>Other</option>
                </select>

                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            @* Challenge description *@
            <div class="mb-4">
                <label asp-for="Description" class="form-label">
                    What are you committing to?
                </label>

                <textarea asp-for="Description"
                          rows="4"
                          class="form-control"></textarea>

                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            @* Target value *@
            <div class="mb-4">
                <label asp-for="TargetValue" class="form-label">
                    Target Amount
                </label>

                <input asp-for="TargetValue"
                       class="form-control"
                       placeholder="Example: 30" />

                <span asp-validation-for="TargetValue"
                      class="text-danger"></span>
            </div>

            @* Unit *@
            <div class="mb-4">
                <label asp-for="Unit" class="form-label">
                    Unit
                </label>

                <select asp-for="Unit" class="form-select">
                    <option value="">Select a unit...</option>
                    <option>Days</option>
                    <option>Books</option>
                    <option>Chapters</option>
                    <option>Pages</option>
                    <option>Miles</option>
                    <option>Minutes</option>
                    <option>Hours</option>
                    <option>Workouts</option>
                    <option>Sessions</option>
                    <option>Count</option>
                </select>

                <span asp-validation-for="Unit"
                      class="text-danger"></span>
            </div>

            @* End date *@
            <div class="mb-4">
                <label asp-for="EndDate" class="form-label">
                    End Date
                </label>

                <input asp-for="EndDate"
                       type="date"
                       class="form-control" />

                <span asp-validation-for="EndDate"
                      class="text-danger"></span>
            </div>

            @* Form actions *@
            <div class="d-flex justify-content-end gap-2">

                <a asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>

                <button type="submit" class="btn btn-primary">
                    Create Challenge
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {

    @* Client-side validation *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}