@model DisciplineDashboard.Models.Challenge

@{
    ViewData["Title"] = "Challenge Details";

    var progressPercent = Model.TargetValue > 0
        ? Math.Min((Model.CurrentValue / Model.TargetValue) * 100, 100)
        : 0;

    var daysRemaining = Model.EndDate.HasValue
        ? (Model.EndDate.Value.ToDateTime(TimeOnly.MinValue).Date - DateTime.Today).Days
        : (int?)null;
}

<div class="page-section">

    @* Page header *@
    <div class="page-header">
        <div>
            <p class="page-kicker">Challenge Details</p>
            <h1>@Model.Name</h1>
            <p>Track progress toward this short-term commitment.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Back to Challenges
        </a>
    </div>

    @* Challenge overview *@
    <div class="dashboard-grid">

        @* Progress summary *@
        <div class="dash-card card-large reveal">
            <div class="card-header-row">
                <h3>Progress</h3>

                @if (Model.IsCompleted)
                {
                    <span class="card-pill">Completed</span>
                }
                else
                {
                    <span class="card-pill">Active</span>
                }
            </div>

            <p class="mission-text">
                @Model.CurrentValue / @Model.TargetValue @Model.Unit
            </p>

            <div class="habit-progress-track mt-3">
                <div class="habit-progress-fill"
                     style="width:@progressPercent%">
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="mt-4">@Model.Description</p>
            }
        </div>

        @* Challenge timeline *@
        <div class="dash-card card-medium reveal">
            <div class="card-header-row">
                <h3>Timeline</h3>
                <span class="card-pill">Dates</span>
            </div>

            <div class="mini-list">
                <div>
                    <span>Started</span>
                    <strong>@Model.StartDate.ToShortDateString()</strong>
                </div>

                <div>
                    <span>End Date</span>
                    <strong>@(Model.EndDate?.ToShortDateString() ?? "No end date")</strong>
                </div>

                @if (Model.IsCompleted && Model.CompletedAt.HasValue)
                {
                    <div>
                        <span>Completed</span>
                        <strong>@Model.CompletedAt.Value.ToShortDateString()</strong>
                    </div>
                }
                else if (daysRemaining.HasValue)
                {
                    <div>
                        <span>Days Remaining</span>
                        <strong>@daysRemaining days</strong>
                    </div>
                }
            </div>
        </div>

        @* Challenge actions *@
        <div class="dash-card card-small reveal">
            <div class="card-header-row">
                <h3>Actions</h3>
            </div>

            <div class="d-flex gap-2">
                @if (!Model.IsCompleted)
                {
                    <a asp-action="Edit"
                       asp-route-id="@Model.ChallengeID"
                       class="btn btn-primary">
                        Update
                    </a>
                }

                <button type="button"
                        class="btn btn-danger"
                        data-bs-toggle="modal"
                        data-bs-target="#deleteChallengeModal-@Model.ChallengeID">
                    Delete
                </button>
            </div>
        </div>
    </div>
</div>

@* Delete confirmation modal *@
<div class="modal fade" id="deleteChallengeModal-@Model.ChallengeID" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header">
                <h5 class="modal-title">Delete Challenge?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                Are you sure you want to delete <strong>@Model.Name</strong>?
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>

                <form asp-action="Delete" asp-route-id="@Model.ChallengeID" method="post">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn btn-danger">
                        Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>