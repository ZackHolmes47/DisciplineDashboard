@*GOALS INDEX*@

@model IEnumerable<DisciplineDashboard.Models.Goal>

@{
    ViewData["Title"] = "Goals";
}

<div class="page-section">

    @* Page header *@
    <div class="page-header">
        <div>
            <p class="page-kicker">Long-term focus</p>
            <h1>Goals</h1>
            <p>Track the bigger outcomes you're working toward.</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">+ Add Goal</a>
    </div>

    @* Goal list *@
    @* Goal list *@
    <div class="habit-groups">

        @* Active goals *@
        <section class="habit-group-card reveal">
            <div class="habit-group-header">
                <h2>Active Goals</h2>
                <span>@Model.Count(g => !g.IsCompleted) active</span>
            </div>

            <div class="habit-list">
                @if (Model.Any(g => !g.IsCompleted))
                {
                    foreach (var goal in Model.Where(g => !g.IsCompleted))
                    {
                        <div class="habit-row">
                            <div>
                                <strong>@goal.Name</strong>

                                @if (!string.IsNullOrWhiteSpace(goal.Description))
                                {
                                    <p>@goal.Description</p>
                                }

                                @if (goal.TargetDate.HasValue)
                                {
                                    <p>Target: @goal.TargetDate.Value.ToShortDateString()</p>
                                }
                            </div>

                            <div class="habit-actions">
                                <a asp-action="Details"
                                   asp-route-id="@goal.GoalID"
                                   class="habit-edit-link">
                                    View
                                </a>
                                <a asp-action="Edit"
                                   asp-route-id="@goal.GoalID"
                                   class="habit-edit-link">
                                    Edit
                                </a>
                                <button type="button"
                                        class="habit-delete-link"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteGoalModal-@goal.GoalID">
                                    Delete
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No active goals yet.</p>
                }
            </div>
        </section>

        @* Completed goals *@
        <section class="habit-group-card reveal">
            <div class="habit-group-header">
                <h2>Completed Goals</h2>
                <span>@Model.Count(g => g.IsCompleted) completed</span>
            </div>

            <div class="habit-list">
                @if (Model.Any(g => g.IsCompleted))
                {
                    foreach (var goal in Model.Where(g => g.IsCompleted))
                    {
                        <div class="habit-row">
                            <div>
                                <strong>@goal.Name</strong>

                                @if (!string.IsNullOrWhiteSpace(goal.Description))
                                {
                                    <p>@goal.Description</p>
                                }

                                @if (goal.TargetDate.HasValue)
                                {
                                    <p>Target: @goal.TargetDate.Value.ToShortDateString()</p>
                                }
                                @if (goal.CompletedAt.HasValue)
                                {
                                    var daysToComplete = (goal.CompletedAt.Value.Date - goal.CreatedAt.Date).Days;

                                    <p>
                                        Completed on @goal.CompletedAt.Value.ToShortDateString()
                                        in @daysToComplete days
                                    </p>
                                }
                            </div>

                            <div class="habit-actions">
                                <a asp-action="Details"
                                   asp-route-id="@goal.GoalID"
                                   class="habit-edit-link">
                                    View
                                </a>
                                <button type="button"
                                        class="habit-delete-link"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteGoalModal-@goal.GoalID">
                                    Delete
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No completed goals yet.</p>
                }
            </div>
        </section>
    </div>
</div>

@* Delete confirmation modals *@
@foreach (var goal in Model)
{
    <div class="modal fade" id="deleteGoalModal-@goal.GoalID" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-4">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Goal?</h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close">
                    </button>
                </div>

                <div class="modal-body">
                    Are you sure you want to delete <strong>@goal.Name</strong>?
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <form asp-action="Delete"
                          asp-route-id="@goal.GoalID"
                          method="post">

                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn btn-danger">
                            Yes, Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}