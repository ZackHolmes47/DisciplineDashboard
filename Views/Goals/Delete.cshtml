@model DisciplineDashboard.Models.Goal

@{
    ViewData["Title"] = "Delete Goal";
}

<div class="page-section">

    @* Page header *@
    <div class="page-header">
        <div>
            <p class="page-kicker">Delete Goal</p>
            <h1>Are you sure?</h1>
            <p>This goal will be removed from your list.</p>
        </div>
    </div>

    @* Delete confirmation *@
    <div class="form-card">

        @* Goal details *@
        <h3>@Model.Name</h3>

        @if (!string.IsNullOrWhiteSpace(Model.Category))
        {
            <p class="text-muted mb-2">
                Category: @Model.Category
            </p>
        }

        @if (Model.TargetDate.HasValue)
        {
            <p class="text-muted">
                Target: @Model.TargetDate.Value.ToShortDateString()
            </p>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p>@Model.Description</p>
        }

        @* Form actions *@
        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="GoalID" />

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>

                <button type="submit" class="btn btn-danger">
                    Delete Goal
                </button>
            </div>
        </form>
    </div>
</div>