@model DisciplineDashboard.Models.Goal

@{
    ViewData["Title"] = "Goal Details";

    var daysRemaining = Model.TargetDate.HasValue
    ? (Model.TargetDate.Value.ToDateTime(TimeOnly.MinValue).Date - DateTime.Today).Days
    : (int?)null;

    var daysToComplete = Model.CompletedAt.HasValue
        ? (Model.CompletedAt.Value.Date - Model.CreatedAt.Date).Days
        : (int?)null;
}

<div class="page-section">

    @* Page header *@
    <div class="page-header">
        <div>
            <p class="page-kicker">Goal Details</p>
            <h1>@Model.Name</h1>
            <p>Review your goal, target date, and current status.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Back to Goals
        </a>
    </div>

    @* Goal overview *@
    <div class="dashboard-grid">

        @* Goal description *@
        <div class="dash-card card-large reveal">
            <div class="card-header-row">
                <h3>Overview</h3>

                @if (Model.IsCompleted)
                {
                    <span class="card-pill">Completed</span>
                }
                else
                {
                    <span class="card-pill">Active</span>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p>@Model.Description</p>
            }
            else
            {
                <p>No description added yet.</p>
            }
        </div>

        @* Goal timeline *@
        <div class="dash-card card-medium reveal">
            <div class="card-header-row">
                <h3>Timeline</h3>
                <span class="card-pill">Dates</span>
            </div>

            <div class="mini-list">
                <div>
                    <span>Created</span>
                    <strong>@Model.CreatedAt.ToShortDateString()</strong>
                </div>

                <div>
                    <span>Target</span>
                    <strong>@(Model.TargetDate?.ToShortDateString() ?? "No target")</strong>
                </div>

                @if (Model.IsCompleted && Model.CompletedAt.HasValue)
                {
                    <div>
                        <span>Completed</span>
                        <strong>@Model.CompletedAt.Value.ToShortDateString()</strong>
                    </div>

                    <div>
                        <span>Finished In</span>
                        <strong>@daysToComplete days</strong>
                    </div>
                }
                else if (daysRemaining.HasValue)
                {
                    <div>
                        <span>Days Remaining</span>
                        <strong>@daysRemaining days</strong>
                    </div>
                }
            </div>
        </div>

        @* Goal actions *@
        <div class="dash-card card-small reveal">
            <div class="card-header-row">
                <h3>Actions</h3>
            </div>

            <div class="d-flex gap-2">
                @if (!Model.IsCompleted)
                {
                    <a asp-action="Edit"
                       asp-route-id="@Model.GoalID"
                       class="btn btn-primary">
                        Edit Goal
                    </a>
                }

                <button type="button"
                        class="btn btn-danger"
                        data-bs-toggle="modal"
                        data-bs-target="#deleteGoalModal-@Model.GoalID">
                    Delete
                </button>
            </div>
        </div>

    </div>

</div>

@* Delete confirmation modal *@
<div class="modal fade" id="deleteGoalModal-@Model.GoalID" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header">
                <h5 class="modal-title">Delete Goal?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                Are you sure you want to delete <strong>@Model.Name</strong>?
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>

                <form asp-action="Delete" asp-route-id="@Model.GoalID" method="post">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn btn-danger">
                        Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>