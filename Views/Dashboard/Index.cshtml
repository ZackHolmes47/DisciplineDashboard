@*DASHBOARD INDEX*@
@model DisciplineDashboard.Models.ViewModels.DashboardViewModel

@using Microsoft.AspNetCore.Identity
@using DisciplineDashboard.Models

@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Home";

    var currentUser = await UserManager.GetUserAsync(User);

    var firstName = currentUser?.FirstName ?? "Friend";

    var hour = DateTime.Now.Hour;

    string greeting;

    if (hour < 12)
    {
        greeting = "Good Morning";
    }
    else if (hour < 18)
    {
        greeting = "Good Afternoon";
    }
    else
    {
        greeting = "Good Evening";
    }
}

<div class="dashboard-page">

    @* Hero greeting *@
    <section class="dashboard-hero">
        <div class="hero-inner">
            <div class="hero-kicker">@greeting,</div>

            <h1 class="hero-title">@firstName</h1>

            <p class="hero-verse">
                “Commit your work to the Lord, and your plans will be established.”
            </p>

            <p class="hero-reference">Proverbs 16:3</p>
        </div>
    </section>

    @* Dashboard stats *@
    <div class="dashboard-stats reveal">
        <div class="stat-card">
            <div class="stat-icon">🔥</div>
            <div>
                <div class="stat-label">Longest Streak</div>
                <div class="stat-value">@Model.CurrentStreak Days</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">✅</div>
            <div>
                <div class="stat-label">Habits Today</div>
                <div class="stat-value">@Model.HabitsCompletedToday/@Model.TotalHabitsToday Completed</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">🎯</div>
            <div>
                <div class="stat-label">Active Goals</div>
                <div class="stat-value">@Model.ActiveGoals Active</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">📖</div>
            <div>
                <div class="stat-label">Journal Entries</div>
                <div class="stat-value">@Model.JournalEntries Total</div>
            </div>
        </div>
    </div>

    @* Main dashboard cards *@
    <section class="dashboard-grid">

        @* Today's mission *@
        <div class="dash-card card-large reveal">

            <div class="card-header-row">
                <h3>Todays Mission</h3>
                <span class="card-pill">Current</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.TodaysMission))
            {
                <p class="mission-text">@Model.TodaysMission</p>
            }
            else
            {
                <p class="mission-text">
                    No mission set for today. Add tomorrow’s mission in tonight’s journal.
                </p>
            }

            <a asp-controller="Journal" asp-action="Index" class="btn btn-primary mt-3">
                Open Journal
            </a>
        </div>

        @* Habit streaks *@
        <div class="dash-card card-medium reveal">
            <div class="card-header-row">
                <h3>Streaks</h3>
                <span class="card-pill">Current</span>
            </div>

            <div class="mini-list">
                @foreach (var streak in Model.Streaks.Take(5))
                {
                    <div class="streak-row">
                        <span>@streak.Name</span>

                        @if (streak.CompletedToday)
                        {
                            <strong class="streak-good">🔥 @streak.CurrentStreak Days</strong>
                        }
                        else if (streak.AtRisk)
                        {
                            <strong class="streak-risk">⚠️ @streak.CurrentStreak Days at risk</strong>
                        }
                        else
                        {
                            <strong class="streak-broken">0 Days</strong>
                        }
                    </div>
                }
            </div>
        </div>

        @* Active goals *@
        <div class="dash-card card-small reveal">
            <div class="card-header-row">
                <h3>Goals</h3>
                <span class="card-pill">Active</span>
            </div>

            <div class="mini-list compact-list">

                @if (Model.ActiveGoalsList.Any())
                {
                    @foreach (var goal in Model.ActiveGoalsList)
                    {
                        <div class="compact-list-item">
                            <span>🎯 @goal.Name</span>
                        </div>
                    }

                    <a asp-controller="Goals"
                       asp-action="Index"
                       class="compact-link">
                        View All →
                    </a>
                }
                else
                {
                    <p>No active goals yet.</p>
                }

            </div>
        </div>

        @* Active challenges *@
        <div class="dash-card card-small reveal">

            <div class="card-header-row">
                <h3>Challenges</h3>
                <span class="card-pill">Active</span>
            </div>

            <div class="mini-list compact-list">

                @if (Model.ActiveChallengesList.Any())
                {
                    @foreach (var challenge in Model.ActiveChallengesList)
                    {
                        <div class="compact-list-item">

                            <span>
                                🏆 @challenge.Name
                            </span>

                            <strong>
                                @challenge.CurrentValue/@challenge.TargetValue
                            </strong>

                        </div>
                    }

                    <a asp-controller="Challenges"
                       asp-action="Index"
                       class="compact-link">
                        View All →
                    </a>
                }
                else
                {
                    <p>No active challenges yet.</p>
                }

            </div>

        </div>

        @* Yesterday's reflection *@
        <div class="dash-card card-small reveal">

            <div class="card-header-row">
                <h3>Yesterdays Reflection</h3>
                <span class="card-pill">Current</span>
            </div>

            @if (Model.YesterdayJournal != null &&
            !string.IsNullOrWhiteSpace(Model.YesterdayJournal.Reflection))
            {
@*                 <p class="label-text">Yesterday’s Reflection</p> *@

                <p>
                    @Model.YesterdayJournal.Reflection
                </p>
            }
            else
            {
                <p>No reflection from yesterday yet.</p>
            }

            <a asp-controller="Journal" asp-action="Index" class="btn btn-primary mt-2">
                Open Journal
            </a>
        </div>

    </section>

    @* Daily check-in *@
    <section class="reveal mt-5">
        <div class="page-header">
            <div>
                <p class="page-kicker">Daily Accountability</p>
                <h1>Today's Check-In</h1>
                <p>Update your progress without leaving the dashboard.</p>
            </div>
        </div>

        <partial name="_DailyCheckIn" model="Model.CheckIn" />
    </section>
</div>