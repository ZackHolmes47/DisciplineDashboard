@{
    ViewData["Title"] = "Features";
}

@* Features overview *@
<div class="container py-5">

    @* Page header *@
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">Everything You Need to Stay Disciplined</h1>
        <p class="lead">
            Discipline Dashboard brings your habits, goals, journals, and progress together in one place.
        </p>
    </div>

    @* Feature cards *@
    <div class="row g-4">

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3>📈 Dashboard</h3>
                    <p>View your overall progress and keep track of what matters most.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3>✅ Habits</h3>
                    <p>Create daily habits, build streaks, and stay consistent over time.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3>🎯 Goals & Challenges</h3>
                    <p>Break large goals into manageable milestones and monitor your progress.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3>📖 Journal</h3>
                    <p>Reflect on your day, document your journey, and celebrate growth.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3>🔒 Private Accounts</h3>
                    <p>Your data belongs to you. Every account has its own secure workspace.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3>📂 Categories</h3>
                    <p>Organize your habits and goals into areas like Health, Faith, Personal, and more.</p>
                </div>
            </div>
        </div>
    </div>
</div>