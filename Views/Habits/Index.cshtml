@*HABITS INDEX*@

@model IEnumerable<DisciplineDashboard.Models.Habit>

@{
    ViewData["Title"] = "Habits";
    var groupedHabits = Model.GroupBy(h => h.Category).OrderBy(g => g.Key);
}

<div class="page-section">

    @* Page header *@
    <div class="page-header">
        <div>
            <p class="page-kicker">Build consistency</p>
            <h1>Habits</h1>
            <p>Manage the daily habits you want to track.</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">+ Add Habit</a>
    </div>

    @{
        var categories = Model
            .Select(h => h.Category)
            .Distinct()
            .OrderBy(c => c)
            .ToList();
    }

    @* Category cards *@
    <div class="life-area-grid mb-4">
        @foreach (var category in categories)
        {
            <a asp-controller="Category"
               asp-action="Details"
               asp-route-category="@category"
               class="life-area-card">

                <div>
                    <p class="page-kicker mb-1">Life Area</p>
                    <h3>@category</h3>
                    <span>@Model.Count(h => h.Category == category) habits</span>
                </div>

                <strong>View →</strong>
            </a>
        }
    </div>

    @* Habit groups *@
    <div class="habit-groups">
        @foreach (var group in groupedHabits)
        {
            <section class="habit-group-card reveal">

                @* Category header *@
                <div class="habit-group-header">
                    <h2>@group.Key</h2>
                    <span>@group.Count() habits</span>
                </div>

                @* Habit list *@
                <div class="habit-list">
                    @foreach (var habit in group)
                    {
                        <div class="habit-row">
                            <div>
                                <strong>@habit.Name</strong>

                                @if (!string.IsNullOrWhiteSpace(habit.Description))
                                {
                                    <p>@habit.Description</p>
                                }
                            </div>

                            <div class="habit-actions">
                                <a asp-action="Edit"
                                   asp-route-id="@habit.HabitID"
                                   class="habit-edit-link">
                                    Edit
                                </a>
                                <button type="button"
                                        class="habit-delete-link"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteHabitModal-@habit.HabitID">
                                    Delete
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }
    </div>
</div>

@* Delete confirmation modals *@
@foreach (var habit in Model)
{
    <div class="modal fade" id="deleteHabitModal-@habit.HabitID" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-4">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Habit?</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    Are you sure you want to delete <strong>@habit.Name</strong>?
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <form asp-action="Delete" asp-route-id="@habit.HabitID" method="post">
                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn btn-danger">
                            Yes, Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}