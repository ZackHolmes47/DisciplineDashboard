@model DisciplineDashboard.Models.Habit

@{
    ViewData["Title"] = "Create Habit";
}

<div class="page-section">

    @* Page header *@
    <div class="page-header">
        <div>
            <p class="page-kicker">New Habit</p>
            <h1>Create a Habit</h1>
            <p>Start building a habit you'll practice consistently.</p>
        </div>
    </div>

    @* Habit form *@
    <div class="form-card">

        <form asp-action="Create" method="post">

            @* Habit name *@
            <div class="mb-4">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            @* Habit category *@
            <div class="mb-4">
                <label asp-for="Category" class="form-label"></label>

                <select asp-for="Category" class="form-select">
                    <option value="">Select a category...</option>
                    <option>Faith</option>
                    <option>Health</option>
                    <option>Personal</option>
                    <option>Work</option>
                    <option>Relationships</option>
                    <option>Other</option>
                </select>

                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            @* Habit description *@
            <div class="mb-4">
                <label asp-for="Description" class="form-label">
                    What do you want to accomplish?
                </label>

                <textarea asp-for="Description"
                          rows="4"
                          class="form-control"></textarea>

                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            @* Daily target *@
            <div class="mb-4">
                <label asp-for="TargetValue" class="form-label">
                    Daily Target
                </label>

                <input asp-for="TargetValue"
                       class="form-control"
                       placeholder="Example: 20" />

                <span asp-validation-for="TargetValue"
                      class="text-danger"></span>
            </div>

            @* Target unit *@
            <div class="mb-4">

                <label asp-for="Unit" class="form-label">
                    Unit
                </label>

                <select asp-for="Unit" class="form-select">

                    <option value="">Select a unit...</option>

                    <option>Minutes</option>
                    <option>Hours</option>

                    <option>Chapters</option>
                    <option>Pages</option>

                    <option>Steps</option>
                    <option>Miles</option>

                    <option>Glasses</option>
                    <option>Gallons</option>
                    <option>Ounces</option>

                    <option>Calories</option>

                    <option>Count</option>

                </select>

                <span asp-validation-for="Unit"
                      class="text-danger"></span>
            </div>

            @* Form actions *@
            <div class="d-flex justify-content-end gap-2">

                <a asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>

                <button type="submit" class="btn btn-primary">
                    Create Habit
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {

    @* Client-side validation *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}