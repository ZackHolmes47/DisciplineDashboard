@*JOURNAL INDEX*@

@model DisciplineDashboard.Models.JournalEntry

@{
    ViewData["Title"] = "Journal";
    var pastEntries = ViewBag.PastEntries as List<DisciplineDashboard.Models.JournalEntry>;
}

<div class="page-section">

    @* Page header *@
    <div class="page-header">
        <div>
            <p class="page-kicker">@Model.Date.ToLongDateString()</p>
            <h1>Journal</h1>
            <p>Reflect, reset, and prepare for tomorrow.</p>
        </div>
    </div>

    @* Journal form *@
    <div class="form-card mb-4">
        <form asp-action="Edit" asp-route-id="@Model.JournalEntryID" method="post">
            <input type="hidden" asp-for="JournalEntryID" />

            @* Morning mission *@
            <div class="mb-4">
                <label asp-for="MorningMission" class="form-label">Morning Mission</label>
                <textarea asp-for="MorningMission" class="form-control" rows="3"></textarea>
            </div>

            @* Gratitude *@
            <div class="mb-4">
                <label asp-for="Gratitude" class="form-label">Gratitude</label>
                <textarea asp-for="Gratitude" class="form-control" rows="3"></textarea>
            </div>

            @* Daily reflection *@
            <div class="mb-4">
                <label asp-for="Reflection" class="form-label">Reflection</label>
                <textarea asp-for="Reflection" class="form-control" rows="4"></textarea>
            </div>

            @* Areas to improve *@
            <div class="mb-4">
                <label asp-for="WhatToImprove" class="form-label">What can I improve?</label>
                <textarea asp-for="WhatToImprove" class="form-control" rows="3"></textarea>
            </div>

            @* Tomorrow's mission *@
            <div class="mb-4">
                <label asp-for="TomorrowMission" class="form-label">Tomorrow's Mission</label>
                <textarea asp-for="TomorrowMission" class="form-control" rows="3"></textarea>
            </div>

            @* Form actions *@
            <button type="submit" class="btn btn-primary">
                Save Journal
            </button>
        </form>
    </div>

    @* Past journal entries *@
    <div class="habit-group-card">
        <div class="habit-group-header">
            <h2>Past Entries</h2>
            <span>@(pastEntries?.Count ?? 0) recent</span>
        </div>

        @if (pastEntries != null && pastEntries.Any())
        {
            foreach (var entry in pastEntries)
            {
                <div class="habit-row">
                    <div>
                        <strong>@entry.Date.ToLongDateString()</strong>
                        <p>@(entry.Reflection ?? "No reflection written.")</p>
                    </div>

                    <a asp-action="Edit" asp-route-id="@entry.JournalEntryID">View/Edit</a>
                </div>
            }
        }
        else
        {
            <p class="text-muted">No past entries yet.</p>
        }
    </div>
</div>